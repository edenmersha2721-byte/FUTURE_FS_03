# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database (local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=beauty_salon_db
DB_USER=postgres
DB_PASSWORD=your_password
# Production (Render) connection string
DATABASE_URL=

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Default admin
ADMIN_EMAIL=admin@luxesalon.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Salon Admin

# Email (Resend) — used to notify customers when a booking is approved.
# Leave RESEND_API_KEY blank to disable emails (approvals still work, no email is sent).
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=
# MAIL_FROM must use a domain verified in Resend. For quick testing you can use
# "Amra Beauty <onboarding@resend.dev>" (only delivers to your Resend account email).
MAIL_FROM=Amra Beauty <onboarding@resend.dev>
SALON_NAME=Amra Beauty
